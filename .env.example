# ──────────────────────────────────────────────────────────────
# CHF Botanical Luxury — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# Cloudflare R2 — Media Storage
# Get these from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=chf-media

# The public URL for your R2 bucket.
# Enable "Public Access" on the bucket in Cloudflare dashboard,
# or connect a custom domain (e.g. media.chfbotanical.com).
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# Admin auth/session
JWT_SECRET=replace_with_long_random_secret
HTTPS_ENABLED=true

# Cloudflare Turnstile (optional but recommended in production)
TURNSTILE_SECRET=your_turnstile_secret

# Cloudflare cache purge (recommended for production CDN sync)
# API token should have "Zone.Cache Purge:Edit" for the target zone.
CF_ZONE_ID=your_cloudflare_zone_id
CF_API_TOKEN=your_cloudflare_api_token_for_cache_purge
