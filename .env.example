# ──────────────────────────────────────────────────────────────
# CHF Botanical Luxury — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# Cloudflare R2 — Media Storage
# Get these from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=chf-media

# The public URL for your R2 bucket.
# Enable "Public Access" on the bucket in Cloudflare dashboard,
# or connect a custom domain (e.g. media.chfbotanical.com).
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
